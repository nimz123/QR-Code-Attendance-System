generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Teacher {
  id             Int      @id @default(autoincrement())
  username       String   @unique
  passwordHash   String
  name           String
  photo          String?
  room           String?
  subject        String?

  sections       Section[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Section {
  id         String @id
  name       String
  startTime  String

  teacherId  Int
  teacher    Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  students   Student[]
  records    AttendanceRecord[]

  @@index([teacherId])
}

model Student {
  id           String @id
  name         String
  username     String @unique
  passwordHash String
  photoUrl     String?

  sectionId  String
  section    Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  records    AttendanceRecord[]
}

model AttendanceRecord {
  id           String @id

  studentId    String
  student      Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  sectionId    String
  section      Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  teacherId    Int

  studentName  String
  sectionName  String

  date         String
  time         String
  status       String
  type         String

  timestamp    DateTime

  @@index([teacherId])
}
